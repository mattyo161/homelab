---
# Copy to secrets.yml in this directory (gitignored) before running k3s plays.
#
#   cp group_vars/k3s_cluster/secrets.yml.example group_vars/k3s_cluster/secrets.yml
#   ansible-vault encrypt group_vars/k3s_cluster/secrets.yml
#
# Run playbooks with: ansible-playbook ... --ask-vault-pass
# Or set vault_password_file in ansible.cfg (local only; do not commit).
#
# Generate a token:
#   openssl rand -base64 64
# Using yq:
#   TOKEN="$(openssl rand -base64 64)" yq '.token = env(TOKEN)' \
#      group_vars/k3s_cluster/secrets.yml.example \
#      > group_vars/k3s_cluster/secrets.yml

token: "changeme-replace-with-openssl-rand-base64-64"
